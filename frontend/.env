# frontend/.env
# For local development, use the server IP with dev backend port
VITE_API_BASE_URL="http://192.168.50.48:8001/api"
# For production (Docker), use: VITE_API_BASE_URL="http://wishlist-backend:8000/api"
                     # For local Docker dev, it can be empty if using proxy, or /api
                     # If not using proxy, or in some build setups:
                     # VITE_API_BASE_URL="http://localhost:8000/api" (when backend runs directly on host)
                     # VITE_API_BASE_URL="/api" (when frontend is served by a server that also proxies /api)