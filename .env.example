# Authentication
FAMILY_PASSWORD_HASH='replace_with_your_bcrypt_password_hash'

# Database Configuration
DATABASE_URL="sqlite:///./data/wishlist.db"

# Family Members Configuration
# Format: Name1:YYYY-MM-DD,Name2:YYYY-MM-DD,Admin:admin
FAMILY_MEMBERS_CONFIG="MemberName1:1990-01-01,MemberName2:1992-02-02,Admin:admin"

# Christmas Date Configuration
CHRISTMAS_MONTH=12
CHRISTMAS_DAY=25

# API Configuration
# For docker-compose deployments, this should be the container name:
BACKEND_URL=http://backend:8000

# Frontend API Base URL
# This should match the endpoint in your nginx config
VITE_API_BASE_URL=http://backend:8000/api

# Rate Limit Webhook Configuration (n8n)
# Used for observability of login attempts, rate limiting events, and lockouts
# Basic auth for webhook security
WEBHOOK_AUTH_USER=
WEBHOOK_AUTH_PASS=

# Development webhook URL (webhook-test endpoint)
DEV_RATELIMIT_WEBHOOK_URL=https://n8n.ariahive.top/webhook-test/security/rate-limit

# Production webhook URL
RATELIMIT_WEBHOOK_URL=https://n8n.ariahive.top/webhook/security/rate-limit
